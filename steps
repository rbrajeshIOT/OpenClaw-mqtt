MIN_ALERT_INTERVAL = 60

last_alert_time = {}

def send_openclaw_alert(sensor_name, message):
    alert_cmd = [
        "/home/rajai/.npm-global/bin/openclaw",
        "message",
        "send",
        "--channel",
        "telegram",
        "--message",
