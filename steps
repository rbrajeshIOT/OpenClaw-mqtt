from ultralytics import YOLO
import cv2, time, os, subprocess
from datetime import datetime
import paho.mqtt.client as mqtt
import json

CAMERA_NAME = "front_door"
RTSP_URL = "rtsp://USER:PASSWORD@CAMERA_IP:554/stream"  # replace

SNAPSHOT_DIR = "snapshots"
os.makedirs(SNAPSHOT_DIR, exist_ok=True)

ALERT_COOLDOWN = 30
last_alert_time = 0

MQTT_BROKER = "localhost"
MQTT_TOPIC = f"home/camera/{CAMERA_NAME}/person"

MODEL = YOLO("yolov8n.pt")

def publish_event(image_path, confidence):
    client = mqtt.Client(mqtt.CallbackAPIVersion.VERSION2)
    client.connect(MQTT_BROKER, 1883, 60)
    payload = {
        "camera": CAMERA_NAME,
        "event": "person_detected",
        "confidence": confidence,
        "image": os.path.abspath(image_path),
        "timestamp": datetime.now().isoformat()
    }
    client.publish(MQTT_TOPIC, json.dumps(payload))
    client.disconnect()

cap = cv2.VideoCapture(RTSP_URL, cv2.CAP_FFMPEG)

if not cap.isOpened():
    print("❌ Cannot open RTSP stream")
    exit()

while True:
    ret, frame = cap.read()
    if not ret:
        print("Failed to grab frame")
        time.sleep(1)
        continue

    results = MODEL(frame, verbose=False)

    for r in results:
        for box in r.boxes:
            cls = int(box.cls[0])
            label = MODEL.names[cls]
            confidence = float(box.conf[0])
            if label == "person" and confidence > 0.6:
                now = time.time()
                if now - last_alert_time > ALERT_COOLDOWN:
                    timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
                    image_path = f"{SNAPSHOT_DIR}/{CAMERA_NAME}_{timestamp}.jpg"
                    cv2.imwrite(image_path, frame)
                    print(f"Person detected! Saved {image_path}")
                    publish_event(image_path, confidence)
                    last_alert_time = now
    time.sleep(0.1)

