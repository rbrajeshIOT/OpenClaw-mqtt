# ==============================================================
# OpenClaw IoT Full Setup
# Self-healing startup, camera + sensors, MQTT + Telegram alerts
# ==============================================================
# Usage: 
# 1. Save this document as ~/device_manager/iot_setup.sh
# 2. Make executable: chmod +x ~/device_manager/iot_setup.sh
# 3. Run once to launch all services: ./iot_setup.sh
# 4. Add to crontab for auto-start on reboot: @reboot ~/device_manager/iot_setup.sh
# ==============================================================

#!/bin/bash

# -----------------------------
# CONFIG
# -----------------------------
VENV=~/device_manager/venv
LOG_DIR=~/device_manager/logs
OPENCLAW_BIN=/home/rajai/.npm-global/bin/openclaw
TELEGRAM_TARGET="@YourTelegramBotUsername"   # replace with your Telegram bot
BROKER="localhost"
MIN_ALERT_INTERVAL=60  # seconds between alerts for the same sensor/camera

mkdir -p "$LOG_DIR"

# -----------------------------
# FUNCTION: start_service
# -----------------------------
start_service() {
    NAME=$1
    CMD=$2
    LOG_FILE="$LOG_DIR/${NAME}.log"
    echo "[INFO] Starting $NAME..."
    while true; do
        echo "[INFO] Running: $CMD"
        eval $CMD >> "$LOG_FILE" 2>&1
        echo "[WARN] $NAME crashed or exited. Restarting in 5 seconds..."
        sleep 5
    done &
}

# -----------------------------
# ACTIVATE VIRTUAL ENV
# -----------------------------
source "$VENV/bin/activate"

# -----------------------------
# START OPENCLAW GATEWAY
# -----------------------------
start_service "gateway" "$OPENCLAW_BIN gateway --port 18789"
sleep 5   # allow gateway to initialize

# -----------------------------
# CAMERA PUBLISHER LISTENER
# (robust, multi-camera, snapshot rotation, thumbnails)
# -----------------------------
start_service "camera_publisher" "python ~/device_manager/camera_publisher.py"

# -----------------------------
# SENSOR LISTENER
# (motion, temperature, door/window sensors)
# -----------------------------
start_service "sensor_listener" "python ~/device_manager/sensor_listener.py"

# -----------------------------
# MQTT LISTENER (if separate from camera/sensor)
# -----------------------------
start_service "mqtt_listener" "python ~/device_manager/mqtt_listener.py"

# -----------------------------
# FINAL MESSAGE
# -----------------------------
echo "[INFO] All services launched and being monitored. Logs in $LOG_DIR"
wait

# ==============================================================
# -----------------------------
# NOTES
# -----------------------------
# - camera_publisher.py: publishes camera events to MQTT with image snapshots
# - sensor_listener.py: subscribes to sensor topics, triggers OpenClaw Telegram alerts
# - mqtt_listener.py: optional; can consolidate camera + sensor events
# - Logs: one per service for easy troubleshooting
# - Alerts: OpenClaw CLI used to send messages to Telegram
# ==============================================================

# -----------------------------
# SENSOR LISTENER EXAMPLE PYTHON (sensor_listener.py)
# -----------------------------
# Paste this into ~/device_manager/sensor_listener.py

